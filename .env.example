# ===========================================
# ग्रामदर्पण - Environment Variables
# ===========================================

# Database URLs (PostgreSQL - Neon / Vercel Postgres / Supabase)
# 1. Go to https://neon.tech → Sign up → Create Project
# 2. Copy the connection string from dashboard
# 3. Set these in Vercel Dashboard > Settings > Environment Variables

# Pooled connection (for Prisma Client in serverless/edge)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection (for Prisma CLI - migrations, db push)
DIRECT_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# For LOCAL development with SQLite (not for Vercel):
# DATABASE_URL="file:./dev.db"
# DIRECT_URL="file:./dev.db"
