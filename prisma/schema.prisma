generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== AUTH & USERS =====

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  nameMarathi String
  role      String   @default("operator") // "gpo" or "operator"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   UserSession[]
  auditLogs  AuditLog[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ipAddress String?
  userAgent String?
  action    String   @default("login")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  recordId  String?
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== MASTER TABLES =====

model VillageInfo {
  id              String   @id @default(cuid())
  gramPanchayatName String
  gramPanchayatNameMr String
  taluka          String
  district        String
  state           String   @default("महाराष्ट्र")
  pinCode         String?
  population      Int?
  totalArea       Float?
  gramSabhaDate   String?
  sarpanchName    String?
  sarpanchNameMr  String?
  secretaryName   String?
  secretaryNameMr String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WardMaster {
  id          String   @id @default(cuid())
  wardNumber  String   @unique
  wardName    String
  wardNameMr  String
  population  Int?
  area        Float?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties  PropertyMaster[]
}

model OwnerMaster {
  id              String   @id @default(cuid())
  ownerNumber     String   @unique
  firstName       String
  middleName      String?
  lastName        String
  firstNameMr     String
  middleNameMr    String?
  lastNameMr      String?
  mobileNumber    String?
  aadhaarNumber   String?
  panNumber       String?
  email           String?
  address         String?
  addressMr       String?
  isDisabled      Boolean  @default(false)
  disabilityType  String?
  disabilityPercentage Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  properties      PropertyOwner[]
}

model RoadMaster {
  id          String   @id @default(cuid())
  roadNumber  String   @unique
  roadName    String
  roadNameMr  String
  roadType    String?
  length      Float?
  width       Float?
  wardId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties  PropertyMaster[]
}

model DrainageMaster {
  id            String   @id @default(cuid())
  drainageNumber String  @unique
  drainageName  String
  drainageNameMr String
  drainageType  String?
  length        Float?
  wardId        String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WaterSupplyMaster {
  id              String   @id @default(cuid())
  connectionNumber String  @unique
  connectionType  String
  connectionStatus String  @default("Active")
  tapSize         String?
  propertyId      String?
  wardId          String?
  monthlyRate     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StreetLightMaster {
  id            String   @id @default(cuid())
  lightNumber   String   @unique
  lightType     String
  wattage       Float?
  poleNumber    String?
  wardId        String?
  roadId        String?
  status        String   @default("Working")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReadyReckonerMaster {
  id                String   @id @default(cuid())
  usageType         String
  constructionType  String
  ratePerSqFt       Float
  year              String
  zone              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([usageType, constructionType, year])
}

model DisabilityMaster {
  id                String   @id @default(cuid())
  disabilityType    String
  disabilityTypeMr  String
  percentageRange   String
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EmployeeMaster {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  firstName     String
  middleName    String?
  lastName      String
  firstNameMr   String
  middleNameMr  String?
  lastNameMr    String?
  designation   String
  designationMr String?
  mobileNumber  String?
  aadhaarNumber String?
  joinDate      String?
  salary        Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TaxMaster {
  id          String   @id @default(cuid())
  name        String
  nameMarathi String
  rate        Float    @default(0)
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propertyTaxRates PropertyTaxRate[]
}

// ===== NEW MASTER TABLES FOR ERP =====

model FinancialYear {
  id          String   @id @default(cuid())
  year        String   @unique  // "2024-25"
  startDate   String
  endDate     String
  isActive    Boolean  @default(true)
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BankAccount {
  id            String   @id @default(cuid())
  accountNumber String   @unique
  bankName      String
  branchName    String?
  ifscCode      String?
  accountType   String   @default("Savings") // Savings, Current, FD
  balance       Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BudgetHead {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameMr      String
  category    String   // "income", "expenditure", "asset", "liability"
  type        String   // "revenue", "capital"
  parentCode  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SchemeInfo {
  id              String   @id @default(cuid())
  schemeNumber    String   @unique
  schemeName      String
  schemeNameMr    String
  schemeType      String?  // "Central", "State", "GP"
  fundSource      String?
  totalAllocation Float    @default(0)
  financialYear   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FloorInfo {
  id          String   @id @default(cuid())
  floorNumber String
  floorName   String
  floorNameMr String
  floorIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DemandCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameMr      String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== PROPERTY WITH LINKS TO MASTERS =====

model PropertyMaster {
  id               String   @id @default(cuid())
  propertyNumber   String   @unique
  wardId           String?
  roadId           String?
  citySurveyNo     String?
  area             Float?
  builtUpArea      Float?
  boundaries       String?
  constructionType String?
  usageType        String?
  floorInfo        String?
  yearBuilt        String?
  propertyStatus   String   @default("Active")
  waterConnectionId String?
  boundaryEast     String?
  boundaryWest     String?
  boundarySouth    String?
  boundaryNorth    String?
  lengthEast       Float?
  widthEast        Float?
  lengthWest       Float?
  widthWest        Float?
  lengthSouth      Float?
  widthSouth       Float?
  lengthNorth      Float?
  widthNorth       Float?
  totalLength      Float?
  totalWidth       Float?
  depreciationRate Float?   @default(0)
  usageFactor      Float?   @default(1)
  taxRate          Float?   @default(0)
  houseTax         Float?   @default(0)
  lightTax         Float?   @default(0)
  healthTax        Float?   @default(0)
  waterTax         Float?   @default(0)
  constructionDetails String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ward            WardMaster?       @relation(fields: [wardId], references: [id])
  road            RoadMaster?       @relation(fields: [roadId], references: [id])
  owners          PropertyOwner[]
  taxRates        PropertyTaxRate[]
  namuna8s        Namuna8[]
  namuna9s        Namuna9[]
  payments        Payment[]
}

model PropertyOwner {
  id           String   @id @default(cuid())
  propertyId   String
  ownerId      String
  ownershipType String  @default("मालक")
  startDate    String?
  endDate      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner    OwnerMaster    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([propertyId, ownerId, ownershipType])
}

model PropertyTaxRate {
  id          String   @id @default(cuid())
  propertyId  String
  taxMasterId String
  rate        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property  PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  taxMaster TaxMaster      @relation(fields: [taxMasterId], references: [id], onDelete: Cascade)

  @@unique([propertyId, taxMasterId])
}

// ===== NAMUNA FORMS =====

model Namuna8 {
  id            String   @id @default(cuid())
  propertyId    String
  financialYear String
  taxDetails    String   @default("[]")
  totalTax      Float    @default(0)
  totalArea        Float?   @default(0)
  landRate         Float?   @default(0)
  buildingRate     Float?   @default(0)
  constructionRate Float?   @default(0)
  depreciationRate Float?   @default(0)
  usageFactor      Float?   @default(1)
  capitalValue     Float?   @default(0)
  taxRatePercent   Float?   @default(0)
  houseTaxAmt      Float?   @default(0)
  lightTaxAmt      Float?   @default(0)
  healthTaxAmt     Float?   @default(0)
  waterTaxAmt      Float?   @default(0)
  totalTaxAmt      Float?   @default(0)
  constructionDetails String?
  appealHouseTax   Float?   @default(0)
  appealLightTax   Float?   @default(0)
  appealHealthTax  Float?   @default(0)
  appealWaterTax   Float?   @default(0)
  appealTotalTax   Float?   @default(0)
  remarks          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Namuna9 {
  id              String   @id @default(cuid())
  propertyId      String
  financialYear   String
  currentTax      Float    @default(0)
  previousBalance Float    @default(0)
  penalty         Float    @default(0)
  interest        Float    @default(0)
  totalDemand     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  propertyId    String
  namuna9Id     String
  amountPaid    Float
  balance       Float
  receiptNumber String
  paymentDate   DateTime @default(now())
  paymentMethod String   @default("Cash")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  namuna9  Namuna9        @relation(fields: [namuna9Id], references: [id], onDelete: Cascade)
}

// ===== DAILY TRANSACTION ENTRIES =====

model ReceiptEntry {
  id              String   @id @default(cuid())
  voucherNumber   String
  receiptDate     String
  financialYear   String
  receivedFrom    String
  receivedFromMr  String?
  amount          Float    @default(0)
  headOfAccount   String?
  headOfAccountMr String?
  description     String?
  descriptionMr   String?
  paymentMethod   String   @default("Cash")
  bankAccountId   String?
  chequeNumber    String?
  isPosted        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentEntry {
  id              String   @id @default(cuid())
  voucherNumber   String
  paymentDate     String
  financialYear   String
  paidTo          String
  paidToMr        String?
  amount          Float    @default(0)
  headOfAccount   String?
  headOfAccountMr String?
  description     String?
  descriptionMr   String?
  paymentMethod   String   @default("Cash")
  bankAccountId   String?
  chequeNumber    String?
  isPosted        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JournalEntry {
  id              String   @id @default(cuid())
  voucherNumber   String
  entryDate       String
  financialYear   String
  debitAccount    String?
  creditAccount   String?
  amount          Float    @default(0)
  description     String?
  descriptionMr   String?
  isPosted        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AssetEntry {
  id              String   @id @default(cuid())
  assetNumber     String   @unique
  assetName       String
  assetNameMr     String
  assetType       String?  // "Building", "Vehicle", "Equipment", "Furniture", "Land", "Other"
  purchaseDate    String?
  purchaseCost    Float    @default(0)
  currentValue    Float    @default(0)
  depreciationRate Float?  @default(10)
  location        String?
  locationMr      String?
  wardId          String?
  status          String   @default("Active")
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StockEntry {
  id              String   @id @default(cuid())
  stockNumber     String   @unique
  itemName        String
  itemNameMr      String
  category        String?
  quantity        Int      @default(0)
  unit            String?  // "Pieces", "Kg", "Liter"
  unitPrice       Float    @default(0)
  totalValue      Float    @default(0)
  receivedDate    String?
  issuedDate      String?
  issuedTo        String?
  status          String   @default("In Stock")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SchemeFundEntry {
  id              String   @id @default(cuid())
  schemeId        String?
  voucherNumber   String
  entryDate       String
  financialYear   String
  amount          Float    @default(0)
  entryType       String   @default("Receipt") // "Receipt", "Payment"
  description     String?
  descriptionMr   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WaterBillEntry {
  id              String   @id @default(cuid())
  propertyId      String?
  connectionId    String?
  billNumber      String
  billDate        String
  financialYear   String
  amount          Float    @default(0)
  penalty         Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  paidDate        String?
  status          String   @default("Pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CollectionEntry {
  id              String   @id @default(cuid())
  collectionNumber String  @unique
  propertyId      String?
  financialYear   String
  collectionDate  String
  amount          Float    @default(0)
  collectionType  String?  // "Tax", "Water", "Light", "Health", "Other"
  receiptNumber   String?
  paymentMethod   String   @default("Cash")
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== BUDGET ENTRY (नमुना १, २, ३ अंदाजपत्रक) =====

model BudgetEntry {
  id              String   @id @default(cuid())
  financialYear   String
  budgetHeadCode  String
  budgetHeadName  String?
  budgetHeadNameMr String?
  category        String   @default("income") // "income", "expenditure"
  type            String   @default("revenue") // "revenue", "capital"
  originalBudget  Float    @default(0)
  revisedBudget   Float    @default(0)
  actualAmount    Float    @default(0)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== WORK ENTRY (विकास कामे) =====

model WorkEntry {
  id                String   @id @default(cuid())
  workNumber        String   @unique
  workName          String
  workNameMr        String
  schemeId          String?
  contractorId      String?
  workType          String?  // "New", "Repair", "Maintenance"
  sanctionDate      String?
  sanctionAmount    Float    @default(0)
  workOrderDate     String?
  completionDate    String?
  progressPercent   Float    @default(0)
  totalExpenditure  Float    @default(0)
  status            String   @default("Sanctioned") // "Sanctioned", "InProgress", "Completed", "Billed"
  financialYear     String?
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ===== CONTRACTOR MASTER =====

model ContractorMaster {
  id              String   @id @default(cuid())
  contractorId    String   @unique
  firstName       String
  middleName      String?
  lastName        String
  firstNameMr     String?
  middleNameMr    String?
  lastNameMr      String?
  firmName        String?
  firmNameMr      String?
  mobileNumber    String?
  aadhaarNumber   String?
  panNumber       String?
  gstNumber       String?
  address         String?
  addressMr       String?
  bankName        String?
  bankAccountNo   String?
  ifscCode        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== SALARY ENTRY =====

model SalaryEntry {
  id              String   @id @default(cuid())
  employeeId      String
  financialYear   String
  month           String   // "January", "February" etc.
  basicPay        Float    @default(0)
  da              Float    @default(0)  // Dearness Allowance
  hra             Float    @default(0)  // House Rent Allowance
  ta              Float    @default(0)  // Travel Allowance
  ma              Float    @default(0)  // Medical Allowance
  otherAllowance  Float    @default(0)
  grossSalary     Float    @default(0)
  pf              Float    @default(0)  // Provident Fund
  esi             Float    @default(0)  // Employee State Insurance
  tds             Float    @default(0)  // Tax Deducted at Source
  professionalTax Float    @default(0)
  otherDeduction  Float    @default(0)
  totalDeduction  Float    @default(0)
  netSalary       Float    @default(0)
  paymentDate     String?
  paymentMethod   String   @default("Bank")
  status          String   @default("Pending") // "Pending", "Paid"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== LEDGER ENTRY (Auto-generated from vouchers) =====

model LedgerEntry {
  id              String   @id @default(cuid())
  financialYear   String
  accountCode     String
  accountName     String?
  accountNameMr   String?
  entryDate       String
  voucherNumber   String
  voucherType     String   // "Receipt", "Payment", "Journal"
  debitAmount     Float    @default(0)
  creditAmount    Float    @default(0)
  balance         Float    @default(0)
  description     String?
  isPosted        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== नमुना १३ - कर्मचारी वर्ग सूची (Employee Category List) =====

model Namuna13 {
  id               String   @id @default(cuid())
  serialNo         Int      @default(0)          // अ.क्र.
  designation      String                        // पदनाम
  designationMr    String?                       // पदनाम (मराठी)
  sanctionedPosts  Int      @default(0)          // मंजुर पदे
  orderNumber      String?                       // आदेश क्रमांक
  orderDate        String?                       // आदेश दिनांक
  employmentType   String   @default("Full-Time") // पूर्णवेळ/अर्धवेळ
  payScale         String?                       // वेतनश्रेणी
  employeeName     String?                       // नियुक्त कर्मचारी नाव
  employeeNameMr   String?                       // नियुक्त कर्मचारी नाव (मराठी)
  appointmentDate  String?                       // नियुक्ती दिनांक
  sarpanchSignature Boolean  @default(false)      // सरपंच सही
  secretarySignature Boolean @default(false)      // सचिव सही
  wardId           String?                       // वार्ड
  status           String   @default("Active")   // स्थिती
  remarks          String?                       // शेरा
  financialYear    String?                       // वित्तीय वर्ष
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ===== नमुना २२ - स्थावर मालमत्ता नोंदवही (Fixed Asset Register) =====

model Namuna22 {
  id                String   @id @default(cuid())
  serialNo          Int      @default(0)        // अ.क्र.
  assetType         String   @default("Building") // "Building", "Dam", "Well", "Other"
  groupName         String?                     // गट / भुमापन क्रमांक
  description       String?                     // मालमत्तेचे वर्णन
  descriptionMr     String?                     // मालमत्तेचे वर्णन (मराठी)
  acquisitionDate   String?                     // संपादन/खरेदीची तारीख
  acquisitionOrder  String?                     // संपादन आदेश क्रमांक
  constructionCost  Float    @default(0)         // उभारणीचा खर्च
  repairCost        Float    @default(0)         // दुरुस्तीचा खर्च
  currentValue      Float    @default(0)         // सध्याचे मूल्य
  location          String?                     // स्थान
  locationMr        String?                     // स्थान (मराठी)
  wardId            String?                     // वार्ड
  status            String   @default("Active")  // स्थिती
  remarks           String?                     // शेरा
  financialYear     String?                     // वित्तीय वर्ष
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ===== नमुना २३ - ताब्यातील रस्त्यांची नोंदवही (Road Register) =====

model Namuna23 {
  id              String   @id @default(cuid())
  serialNo        Int      @default(0)          // अ.क्र.
  roadName        String                        // रस्त्याचे नाव
  roadNameMr      String?                       // रस्त्याचे नाव (मराठी)
  roadLength      Float    @default(0)          // लांबी (कि.मी.)
  roadWidth       Float    @default(0)          // रुंदी (मीटर)
  roadType        String   @default("Kaccha")   // प्रकार: "Kaccha" खडीचा, "Pucca" डांबरी, "Cement" सिमेंटचा
  constructionYear String?                      // बांधणीचे वर्ष
  wardId          String?                       // वार्ड
  fromLocation    String?                       // कोठून
  toLocation      String?                       // कोठेपर्यंत
  status          String   @default("Active")   // स्थिती
  remarks         String?                       // शेरा
  financialYear   String?                       // वित्तीय वर्ष
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== नमुना २४ - जमिनीची नोंदवही (Land Register) =====

model Namuna24 {
  id              String   @id @default(cuid())
  serialNo        Int      @default(0)          // अ.क्र.
  groupName       String?                       // गट / भुमापन क्रमांक
  landType        String   @default("Open")     // प्रकार: "Open" मोकळी जागा, "Gairan" गायरान, "Farm" शेतजमीन, "Other"
  areaHectares    Float    @default(0)          // क्षेत्रफळ (हेक्टर)
  areaSqMeters    Float    @default(0)          // क्षेत्रफळ (चौ.मी.)
  acquisitionDate String?                       // संपादन तारीख
  acquisitionOrder String?                      // संपादन आदेश क्रमांक
  boundaryEast    String?                       // पूर्वेला
  boundaryWest    String?                       // पश्चिमेला
  boundaryNorth   String?                       // उत्तरेला
  boundarySouth   String?                       // दक्षिणेला
  currentUse      String?                       // सध्याचा वापर
  leaseInfo       String?                       // पट्टा माहिती
  wardId          String?                       // वार्ड
  status          String   @default("Active")   // स्थिती
  remarks         String?                       // शेरा
  financialYear   String?                       // वित्तीय वर्ष
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ===== नमुना ३३ - वृक्ष नोंदवही (Tree Register) =====

model Namuna33 {
  id              String   @id @default(cuid())
  serialNo        Int      @default(0)          // अ.क्र.
  treeType        String                        // झाडाचा प्रकार
  treeTypeMr      String?                       // झाडाचा प्रकार (मराठी)
  location        String?                       // स्थान
  locationMr      String?                       // स्थान (मराठी)
  roadName        String?                       // रस्त्याचे नाव
  roadNameMr      String?                       // रस्त्याचे नाव (मराठी)
  plantYear       String?                       // लावणीचे वर्ष
  height          Float    @default(0)          // उंची (फूट)
  girth           Float    @default(0)          // घेर (फूट)
  condition       String   @default("Healthy")  // स्थिती: "Healthy", "Damaged", "Dead"
  wardId          String?                       // वार्ड
  ownership       String   @default("GP")       // मालकी: "GP" ग्रामपंचायत, "Private", "Government"
  estimatedValue  Float    @default(0)          // अंदाजे मूल्य
  remarks         String?                       // शेरा
  financialYear   String?                       // वित्तीय वर्ष
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
