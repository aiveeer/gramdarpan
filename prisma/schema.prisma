generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== AUTH & USERS =====

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  nameMarathi String
  role      String   @default("operator")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   UserSession[]
  auditLogs  AuditLog[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ipAddress String?
  userAgent String?
  action    String   @default("login")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  recordId  String?
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== MASTER TABLES =====

model VillageInfo {
  id              String   @id @default(cuid())
  gramPanchayatName String
  gramPanchayatNameMr String
  taluka          String
  district        String
  state           String   @default("महाराष्ट्र")
  pinCode         String?
  population      Int?
  totalArea       Float?
  gramSabhaDate   String?
  sarpanchName    String?
  sarpanchNameMr  String?
  secretaryName   String?
  secretaryNameMr String?
  financialYear   String   @default("2024-25")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WardMaster {
  id        String   @id @default(cuid())
  wardNo    Int      @unique
  wardName  String
  wardNameMr String
  population Int?
  households Int?
  area       Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  properties PropertyMaster[]
}

model OwnerMaster {
  id          String   @id @default(cuid())
  ownerName   String
  ownerNameMr String?
  aadhaarNo   String?
  mobileNo    String?
  address     String?
  addressMr   String?
  wardNo      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties PropertyMaster[]
}

model PropertyMaster {
  id            String   @id @default(cuid())
  propertyNo    String   @unique
  ownerName     String
  ownerNameMr   String?
  propertyType  String
  propertyUse   String?
  wardId        String?
  areaSqFt      Float?
  constructionType String?
  floors        Int      @default(1)
  constructionYear Int?
  isTaxExempt   Boolean  @default(false)
  waterConnection Boolean @default(false)
  electricityConnection Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ward         WardMaster?  @relation(fields: [wardId], references: [id])
  owner        OwnerMaster? @relation(fields: [ownerId], references: [id])
  ownerId      String?
  taxAssessments Namuna8[]
  demands      Namuna9[]
  payments     Payment[]
}

model TaxMaster {
  id          String   @id @default(cuid())
  taxName     String
  taxNameMr   String
  taxType     String
  taxRate     Float
  unit        String   @default("INR")
  financialYear String @default("2024-25")
  isEnabled   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Namuna8 {
  id             String   @id @default(cuid())
  propertyId     String
  financialYear  String   @default("2024-25")
  propertyTax    Float    @default(0)
  waterTax       Float    @default(0)
  lightTax       Float    @default(0)
  professionTax  Float    @default(0)
  miscTax        Float    @default(0)
  totalTax       Float    @default(0)
  concession     Float    @default(0)
  netDemand      Float    @default(0)
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Namuna9 {
  id             String   @id @default(cuid())
  propertyId     String
  financialYear  String   @default("2024-25")
  openingBalance Float    @default(0)
  totalDemand    Float    @default(0)
  totalCollection Float   @default(0)
  closingBalance Float    @default(0)
  penalty        Float    @default(0)
  discount       Float    @default(0)
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  propertyId    String
  receiptNo     String   @unique
  financialYear String   @default("2024-25")
  amount        Float
  totalDemand   Float
  amountPaid    Float
  balance       Float    @default(0)
  paymentDate   DateTime @default(now())
  paymentMode   String   @default("cash")
  chequeNo      String?
  bankName      String?
  collectedBy   String?
  remarks       String?
  createdAt     DateTime @default(now())

  property PropertyMaster @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model EmployeeMaster {
  id              String   @id @default(cuid())
  employeeName    String
  employeeNameMr  String?
  designation     String
  designationMr   String?
  department      String?
  payScale        String?
  basicPay        Float?
  da              Float?
  hra             Float?
  grossSalary     Float?
  qualification   String?
  dateOfJoining   String?
  dateOfRetirement String?
  bankAccountNo   String?
  pfNo            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  salaries        SalaryEntry[]
}

model Namuna22 {
  id                String   @id @default(cuid())
  propertyName      String
  propertyNameMr    String?
  propertyDesc      String?
  propertyDescMr    String?
  acquisitionDate   String?
  acquisitionMode   String?
  originalValue     Float?
  constructionCost  Float?
  currentValue      Float?
  location          String?
  areaSqFt          Float?
  mapNo             String?
  plotNo            String?
  usageType         String?
  condition         String?
  remarks           String?
  financialYear     String   @default("2024-25")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Namuna23 {
  id              String   @id @default(cuid())
  roadName        String
  roadNameMr      String?
  roadType        String?
  roadLength      Float?
  roadWidth       Float?
  surfaceType     String?
  constructionYear String?
  lastRepairYear  String?
  estimatedCost   Float?
  location        String?
  connectingFrom  String?
  connectingTo    String?
  condition       String?
  remarks         String?
  financialYear   String   @default("2024-25")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Namuna24 {
  id              String   @id @default(cuid())
  landName        String
  landNameMr      String?
  surveyNo        String?
  areaAcres       Float?
  areaHectares    Float?
  areaGunthe      Float?
  landType        String?
  ownershipType   String?
  eastBoundary    String?
  westBoundary    String?
  northBoundary   String?
  southBoundary   String?
  usageType       String?
  mapNo           String?
  gatNo           String?
  remarks         String?
  financialYear   String   @default("2024-25")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Namuna33 {
  id              String   @id @default(cuid())
  treeType        String
  treeTypeMr      String?
  location        String?
  plantDate       String?
  height          Float?
  girth           Float?
  canopyDiameter  Float?
  condition       String?
  estimatedValue  Float?
  ownershipType   String?
  caretaker       String?
  isProtected     Boolean  @default(false)
  remarks         String?
  financialYear   String   @default("2024-25")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReceiptEntry {
  id            String   @id @default(cuid())
  receiptNo     String   @unique
  receiptDate   DateTime @default(now())
  financialYear String   @default("2024-25")
  payerName     String
  payerNameMr   String?
  amount        Float
  taxType       String
  paymentMode   String   @default("cash")
  chequeNo      String?
  bankName      String?
  description   String?
  createdAt     DateTime @default(now())
}

model PaymentEntry {
  id            String   @id @default(cuid())
  voucherNo     String   @unique
  voucherDate   DateTime @default(now())
  financialYear String   @default("2024-25")
  payeeName     String
  payeeNameMr   String?
  amount        Float
  headOfAccount String
  paymentMode   String   @default("cash")
  chequeNo      String?
  bankName      String?
  description   String?
  createdAt     DateTime @default(now())
}

model VoucherEntry {
  id            String   @id @default(cuid())
  voucherNo     String   @unique
  voucherDate   DateTime @default(now())
  financialYear String   @default("2024-25")
  voucherType   String
  amount        Float
  debitAccount  String
  creditAccount String
  narration     String?
  createdAt     DateTime @default(now())
}

model BudgetHead {
  id            String   @id @default(cuid())
  headName      String
  headNameMr    String?
  headCode      String   @unique
  category      String?
  financialYear String   @default("2024-25")
  budgetAmount  Float    @default(0)
  revisedAmount Float?
  expenditure   Float    @default(0)
  balance       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  budgetEntries BudgetEntry[]
  works         WorkEntry[]
}

model BudgetEntry {
  id            String   @id @default(cuid())
  financialYear String   @default("2024-25")
  headId        String
  budgetType    String
  amount        Float
  description   String?
  approvedDate  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  head BudgetHead @relation(fields: [headId], references: [id], onDelete: Cascade)
}

model WorkEntry {
  id              String   @id @default(cuid())
  workName        String
  workNameMr      String?
  schemeName      String?
  headId          String?
  estimatedCost   Float
  approvedCost    Float?
  tenderAmount    Float?
  contractorName  String?
  contractorMr    String?
  startDate       String?
  endDate         String?
  completionDate  String?
  progressPercent Float    @default(0)
  status          String   @default("planned")
  financialYear   String   @default("2024-25")
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  head BudgetHead? @relation(fields: [headId], references: [id])
}

model SalaryEntry {
  id            String   @id @default(cuid())
  employeeId    String
  month         String
  year          Int
  basicPay      Float
  da            Float    @default(0)
  hra           Float    @default(0)
  ma            Float    @default(0)
  deductions    Float    @default(0)
  netPay        Float
  paymentDate   DateTime @default(now())
  paymentMode   String   @default("bank_transfer")
  financialYear String   @default("2024-25")
  createdAt     DateTime @default(now())

  employee EmployeeMaster @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ContractorMaster {
  id              String   @id @default(cuid())
  contractorName  String
  contractorNameMr String?
  aadhaarNo       String?
  bankAccountNo   String?
  bankName        String?
  ifscCode        String?
  mobileNo        String?
  address         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AssetEntry {
  id              String   @id @default(cuid())
  assetName       String
  assetNameMr     String?
  assetType       String?
  category        String?
  purchaseDate    String?
  purchaseCost    Float?
  currentValue    Float?
  depreciation    Float    @default(0)
  location        String?
  condition       String?
  serialNo        String?
  description     String?
  financialYear   String   @default("2024-25")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StockEntry {
  id            String   @id @default(cuid())
  itemName      String
  itemNameMr    String?
  category      String?
  unit          String?
  quantity      Int      @default(0)
  ratePerUnit   Float?
  totalValue    Float?
  minStock      Int?
  maxStock      Int?
  lastPurchaseDate String?
  supplier      String?
  financialYear String   @default("2024-25")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BankAccount {
  id          String   @id @default(cuid())
  bankName    String
  branchName  String?
  accountNo   String   @unique
  ifscCode    String?
  accountType String?
  balance     Float    @default(0)
  openingBalance Float @default(0)
  financialYear String   @default("2024-25")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SchemeInfo {
  id          String   @id @default(cuid())
  schemeName  String
  schemeNameMr String?
  schemeCode  String?
  schemeType  String?
  department  String?
  grantAmount Float?
  receivedAmount Float @default(0)
  expenditure Float  @default(0)
  balance     Float  @default(0)
  financialYear String @default("2024-25")
  startDate   String?
  endDate     String?
  status      String @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialYear {
  id            String   @id @default(cuid())
  yearLabel     String   @unique
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(false)
  isCurrent     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model FloorInfo {
  id            String   @id @default(cuid())
  floorNo       Int
  floorName     String
  floorNameMr   String?
  factor        Float    @default(1.0)
  createdAt     DateTime @default(now())
}

model RoadMaster {
  id          String   @id @default(cuid())
  roadNo      String   @unique
  roadName    String
  roadNameMr  String?
  roadType    String?
  lengthM     Float?
  widthM      Float?
  wardNo      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
